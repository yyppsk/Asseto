{
  "name": "asseto-spa-scroll",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "dev": "vite build --config frontend/vite.config.js && node backend/src/server.js",
    "dev:frontend": "vite --config frontend/vite.config.js --host 0.0.0.0",
    "dev:local": "node frontend/scripts/dev-server.mjs",
    "build": "vite build --config frontend/vite.config.js",
    "start": "node backend/src/server.js",
    "docker:build": "docker build -t asseto-spa-scroll ."
  },
  "dependencies": {
    "three": "^0.184.0"
  },
  "devDependencies": {
    "vite": "^5.3.0"
  }
}
